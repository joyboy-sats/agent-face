{
  "name": "@agent-face/vue",
  "version": "1.0.7",
  "description": "Vue component for deterministic crypto avatars from wallet addresses, public keys, hashes, and any stable string.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/joyboy-sats/agent-face.git",
    "directory": "packages/vue"
  },
  "homepage": "https://agent-face.ch4.app",
  "bugs": {
    "url": "https://github.com/joyboy-sats/agent-face/issues"
  },
  "keywords": [
    "agentface",
    "vue",
    "avatar",
    "svg",
    "robot",
    "vue-avatar",
    "deterministic-avatar",
    "svg-avatar",
    "wallet-avatar",
    "address-avatar",
    "crypto-avatar",
    "hash-avatar",
    "seed-avatar",
    "wallet-address",
    "public-key",
    "web3-ui",
    "wallet-ui",
    "onchain-identity",
    "profile-avatar",
    "ethereum",
    "evm",
    "solana",
    "bitcoin",
    "multichain-avatar",
    "dapp-avatar"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm --dir ../core build && pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-face/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  }
}
