{
  "name": "@agent-face/vue",
  "version": "1.0.2",
  "description": "Vue wrapper for deterministic AgentFace robot avatars.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/joyboy-sats/agent-face.git",
    "directory": "packages/vue"
  },
  "homepage": "https://agent-face.ch4.app",
  "bugs": {
    "url": "https://github.com/joyboy-sats/agent-face/issues"
  },
  "keywords": [
    "agentface",
    "vue",
    "avatar",
    "svg",
    "robot"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-face/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  }
}
