{
  "name": "@agent-face/core",
  "version": "1.0.3",
  "description": "Deterministic seed-to-SVG robot avatar core for AgentFace.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/joyboy-sats/agent-face.git",
    "directory": "packages/core"
  },
  "homepage": "https://agent-face.ch4.app",
  "bugs": {
    "url": "https://github.com/joyboy-sats/agent-face/issues"
  },
  "keywords": [
    "agentface",
    "avatar",
    "svg",
    "robot",
    "seed",
    "deterministic"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
