{
  "name": "@agent-face/core",
  "version": "1.0.6",
  "description": "Chain-agnostic deterministic SVG avatar generator for wallet addresses, public keys, hashes, and any stable string.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/joyboy-sats/agent-face.git",
    "directory": "packages/core"
  },
  "homepage": "https://agent-face.ch4.app",
  "bugs": {
    "url": "https://github.com/joyboy-sats/agent-face/issues"
  },
  "keywords": [
    "agentface",
    "avatar",
    "svg",
    "robot",
    "seed",
    "deterministic",
    "deterministic-avatar",
    "svg-avatar",
    "wallet-avatar",
    "address-avatar",
    "crypto-avatar",
    "hash-avatar",
    "seed-avatar",
    "wallet-address",
    "public-key",
    "web3-ui",
    "wallet-ui",
    "onchain-identity",
    "profile-avatar",
    "ethereum",
    "evm",
    "solana",
    "bitcoin",
    "evm-address",
    "multichain-avatar"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
